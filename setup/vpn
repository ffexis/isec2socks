#!/bin/bash

# ================= CONFIGURATION =================
VPN_CMD="/opt/iSecSP/vpn_cmdline"
DAEMON_CMD="/usr/bin/isecspdaemon"
CONFIG_FILE="/etc/vpn-conf.json"

# Load config from JSON file
if [ ! -f "$CONFIG_FILE" ]; then
    echo "[ERROR] Config file $CONFIG_FILE not found!"
    exit 1
fi

VPN_HOST=$(jq -r '.VPN_HOST' "$CONFIG_FILE")
VPN_USER=$(jq -r '.VPN_USER' "$CONFIG_FILE")
VPN_PASS=$(jq -r '.VPN_PASS' "$CONFIG_FILE")
VPN_SECOND_AUTH=$(jq -r '.VPN_SECOND_AUTH' "$CONFIG_FILE")

# Environment variables override config file
[ -n "$VPN_HOST" ] && VPN_HOST="$VPN_HOST"
[ -n "$VPN_USER" ] && VPN_USER="$VPN_USER"
[ -n "$VPN_PASS" ] && VPN_PASS="$VPN_PASS"
[ -n "$VPN_SECOND_AUTH" ] && VPN_SECOND_AUTH="$VPN_SECOND_AUTH"

# Validate required config
for var in VPN_HOST VPN_USER VPN_PASS VPN_SECOND_AUTH; do
    if [ -z "${!var}" ] || [ "${!var}" = "null" ]; then
        echo "[ERROR] Missing required config: $var"
        exit 1
    fi
done
# =================================================

# Force container to use UTF-8 encoding
export LANG=C.UTF-8
export LC_ALL=C.UTF-8

# [Daemon Guardian] Always check core service first
if ! pgrep -f "isecspdaemon" > /dev/null; then
    echo "[MONITOR] Core daemon is not running. Reviving..."
    $DAEMON_CMD > /dev/null 2>&1 &
    sleep 1.5
fi

case "$1" in
    on|login|start)
        echo "[START] Launching network stack (Pipeline Injection Mode)..."
        > /var/log/vpn_cli.log
        
        # 1. Inject password & fixing the log encoding issue on the fly using python/printf
        nohup sh -c "echo '$VPN_SECOND_AUTH' | $VPN_CMD -h '$VPN_HOST' -u '$VPN_USER' -p '$VPN_PASS'" > /var/log/vpn_cli.log 2>&1 &
        
        # 2. Launch gost proxy
        if ! pgrep -f "gost -L" > /dev/null; then
            echo "[COMPONENT] Launching GOST proxy on port 31080..."
            nohup gost -L :31080 > /var/log/gost.log 2>&1 &
        fi
        
        # 3. Launch route guardian
        if ! pgrep -f "vpn-route-guardian" > /dev/null; then
            echo "[COMPONENT] Launching local route guardian..."
            nohup bash -c '
                exec -a vpn-route-guardian bash -c "
                while true; do
                    if ! ip route | grep -q \"192.168.31.0/24\"; then
                        ip route add 192.168.31.0/24 via 172.19.0.1 dev eth0 2>/dev/null
                    fi
                    sleep 3
                done
                "
            ' > /dev/null 2>&1 &
        fi
        
        # 4. Stream and Decode Logs (Fixing the \xxxx Unicode/Octal escape issue)
        echo "=== [LOGS] Streaming active login logs (Auto-detach in 10s) ==="
        timeout 10 tail -f /var/log/vpn_cli.log | while read -r line; do
            # If the line contains escapes, force echo to parse it or fallback to raw
            echo -e "$line" 2>/dev/null || echo "$line"
        done
        echo "=== [LOGS] Stream ended. Check status via 'vpn status' ==="
        ;;
        
    off|logout|stop)
        echo "[STOP] Tearing down network stack..."
        $VPN_CMD -s
        pkill -f "gost -L"
        pkill -f "vpn-route-guardian"
        echo "[SUCCESS] All associated processes cleared."
        ;;
        
    status|info|show)
        echo "=== [STATUS] VPN Connection Status ==="
        # Fix vpn_cmdline output encoding block
        $VPN_CMD -a | while read -r line; do echo -e "$line" 2>/dev/null || echo "$line"; done
        echo ""
        echo "=== [STATUS] Auxiliary Services ==="
        pgrep -f "gost -L" > /dev/null && echo "  GOST Proxy     : RUNNING (Port 31080)" || echo "  GOST Proxy     : DOWN"
        pgrep -f "vpn-route-guardian" > /dev/null && echo "  Route Guardian : RUNNING" || echo "  Route Guardian : DOWN"
        echo ""
        echo "=== [STATUS] Kernel Routing Table ==="
        ip route | grep -E "tun0|192.168.31" --color=always
        ;;
        
    api)
        case "$2" in
            start)
                /usr/local/bin/start-api.sh
                ;;
            stop)
                PID_FILE="/var/run/vpn-api.pid"
                if [ -f "$PID_FILE" ]; then
                    kill $(cat "$PID_FILE") 2>/dev/null
                    rm -f "$PID_FILE"
                    echo "[API] VPN API server stopped."
                else
                    echo "[API] API server not running."
                fi
                ;;
            *)
                echo "Usage: vpn api {start|stop}"
                ;;
        esac
        ;;
        
    *)
        echo "Invalid usage!"
        echo "  vpn on       - Connect VPN + proxy + route guardian"
        echo "  vpn off      - Disconnect and clean up"
        echo "  vpn status   - View connection and routing status"
        echo "  vpn api start|stop - Manage API server"
        ;;
esac
